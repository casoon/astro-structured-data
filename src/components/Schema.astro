---
// @ts-ignore
import { getGlobalConfig } from 'virtual:astro-structured-data/config';
import { registerSchema } from '../utils/graph';
import { generateMetaTags } from '../utils/meta';

interface Props {
  item: Record<string, any>;
}

const { item } = Astro.props;
const config = getGlobalConfig();
const useGraph = config.useGraph || false;
const generateMeta = config.generateMeta || false;

if (useGraph) {
  registerSchema(Astro.locals, item);
}

// Safe serialization of the JSON-LD schema (for inline fallback mode)
const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  ...item,
});

const sitemapAttrs: Record<string, string> = {};
if (item.changefreq) {
  sitemapAttrs['data-sitemap-changefreq'] = item.changefreq;
}
if (item.priority !== undefined) {
  sitemapAttrs['data-sitemap-priority'] = item.priority.toString();
}

// Only primary schema types generate meta tags; first one per page wins.
const PRIMARY_META_TYPES = new Set([
  'Article', 'BlogPosting', 'NewsArticle',
  'WebPage', 'ItemPage', 'AboutPage', 'ContactPage', 'CollectionPage',
  'Product', 'ProductGroup',
  'LocalBusiness',
  'Event',
  'JobPosting',
  'SoftwareApplication', 'WebApplication', 'MobileApplication',
  'ProfilePage',
  'FAQPage',
  'WebSite',
]);

const canGenerateMeta = !useGraph && generateMeta && PRIMARY_META_TYPES.has(item['@type']);
const alreadyGenerated = !!Astro.locals.__structuredDataMetaGenerated;
if (canGenerateMeta && !alreadyGenerated) {
  Astro.locals.__structuredDataMetaGenerated = true;
}
const seo = canGenerateMeta && !alreadyGenerated
  ? generateMetaTags(item, {
      siteUrl: config.siteUrl,
      canonicalUrl: Astro.url.href,
      siteName: config.siteName,
      locale: config.locale,
      twitterSite: config.twitterSite,
      twitterCreator: config.twitterCreator,
    })
  : null;
---
{!useGraph && (
  <>
    {seo?.canonical && <link rel="canonical" href={seo.canonical} />}
    {seo?.description && <meta name="description" content={seo.description} />}
    {seo?.robots && <meta name="robots" content={seo.robots} />}
    {seo?.author && <meta name="author" content={seo.author} />}
    {seo?.readingTime && <meta name="reading-time" content={seo.readingTime} />}
    {seo?.alternates?.map(({ href, hreflang }) => (
      <link rel="alternate" hreflang={hreflang} href={href} />
    ))}
    {seo && Object.entries(seo.openGraph).map(([prop, val]) => (
      Array.isArray(val)
        ? val.map((v) => <meta property={prop} content={v} />)
        : <meta property={prop} content={val} />
    ))}
    {seo && Object.entries(seo.twitter).map(([name, val]) => (
      <meta name={name} content={val} />
    ))}
    <script type="application/ld+json" {...(seo?.sitemapAttrs || sitemapAttrs)} set:html={jsonLd} />
  </>
)}

