---
// SchemaGraph.astro
// Renders all registered schemas as a single @graph block to optimize SEO.
// @ts-ignore
import { getGlobalConfig } from 'virtual:astro-structured-data/config';
import { generateMetaTags } from '../utils/meta';

const graph = Astro.locals.structuredDataGraph || [];
const hasItems = graph.length > 0;

// Remove the individual @context fields inside the graph items to keep it clean,
// since the root object will have the global @context: 'https://schema.org'.
const cleanedGraph = graph.map((item: any) => {
  const { '@context': _, ...rest } = item;
  return rest;
});

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': cleanedGraph,
});

const config = getGlobalConfig();
const generateMeta = config.generateMeta || false;

// Determine primary item from the graph for meta tags generation
const primaryTypes = ['Article', 'BlogPosting', 'NewsArticle', 'Product', 'LocalBusiness', 'FAQPage', 'WebSite', 'WebPage'];
function findPrimaryItem(items: any[]) {
  for (const type of primaryTypes) {
    const item = items.find(it => it['@type'] === type);
    if (item) return item;
  }
  return items[0];
}

const primaryItem = hasItems ? findPrimaryItem(graph) : null;

const sitemapAttrs: Record<string, string> = {};
if (primaryItem) {
  if (primaryItem.changefreq) {
    sitemapAttrs['data-sitemap-changefreq'] = primaryItem.changefreq;
  }
  if (primaryItem.priority !== undefined) {
    sitemapAttrs['data-sitemap-priority'] = primaryItem.priority.toString();
  }
}

const seo = primaryItem && generateMeta 
  ? generateMetaTags(primaryItem, {
      siteUrl: config.siteUrl,
      canonicalUrl: Astro.url.href,
      siteName: config.siteName,
      locale: config.locale,
      twitterSite: config.twitterSite,
      twitterCreator: config.twitterCreator,
    })
  : null;
---
{hasItems && (
  <>
    {seo?.canonical && <link rel="canonical" href={seo.canonical} />}
    {seo?.description && <meta name="description" content={seo.description} />}
    {seo?.robots && <meta name="robots" content={seo.robots} />}
    {seo?.author && <meta name="author" content={seo.author} />}
    {seo?.readingTime && <meta name="reading-time" content={seo.readingTime} />}
    {seo?.alternates?.map(({ href, hreflang }) => (
      <link rel="alternate" hreflang={hreflang} href={href} />
    ))}
    {seo && Object.entries(seo.openGraph).map(([prop, val]) => (
      Array.isArray(val)
        ? val.map((v) => <meta property={prop} content={v} />)
        : <meta property={prop} content={val} />
    ))}
    {seo && Object.entries(seo.twitter).map(([name, val]) => (
      <meta name={name} content={val} />
    ))}
    <script type="application/ld+json" {...(seo?.sitemapAttrs || sitemapAttrs)} set:html={jsonLd} />
  </>
)}
