---
import Layout from '../layouts/Layout.astro';
import { VideoSchema, WebPageSchema } from 'astro-structured-data/components';

const video = {
  name: 'Einführung in Astro v6 und Server Islands',
  description: 'In diesem Tutorial lernen wir die neuen Features von Astro v6 kennen, inklusive Server Islands und Performance-Optimierungen.',
  thumbnailUrl: 'https://example.com/images/astro-v6-tutorial.jpg',
  uploadDate: '2026-06-01',
  duration: 'PT8M45S',
  contentUrl: 'https://example.com/videos/astro-v6.mp4',
  embedUrl: 'https://example.com/embed/astro-v6',
  interactionCount: 15420,
  publisher: { name: 'casoon GmbH', logoUrl: 'https://casoon.de/logo.png' },
};
---

<Layout 
  title="Astro v6 Video Tutorial" 
  description="Lerne Astro v6 Server Islands kennen. Diese Seite demonstriert das VideoSchema."
>
  <WebPageSchema
    title="Astro v6 Video Tutorial"
    description="Video-Tutorial über Astro v6 Server Islands und Performance-Optimierungen."
    inLanguage="de"
  />

  <VideoSchema
    name={video.name}
    description={video.description}
    thumbnailUrl={video.thumbnailUrl}
    uploadDate={video.uploadDate}
    duration={video.duration}
    contentUrl={video.contentUrl}
    embedUrl={video.embedUrl}
    interactionCount={video.interactionCount}
    publisher={video.publisher}
  />

  <div class="grid">
    <div>
      <span class="badge" style="margin-bottom: 12px;">Video Schema</span>
      <h1>{video.name}</h1>
      <p style="color: var(--text-secondary); margin-bottom: 24px;">
        {video.description}
      </p>

      <div class="card" style="padding: 0; overflow: hidden; border-radius: 8px; border: 1px solid var(--border-color); background: #000; position: relative; aspect-ratio: 16/9; margin-bottom: 20px; display: flex; align-items: center; justify-content: center;">
        <!-- Simple mock video player UI -->
        <div style="position: absolute; width: 100%; height: 100%; background: linear-gradient(0deg, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0) 50%);"></div>
        <div style="z-index: 2; width: 64px; height: 64px; border-radius: 50%; background: rgba(56, 189, 248, 0.9); border: 2px fill white; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 4px 10px rgba(0,0,0,0.3); transition: transform 0.2s;">
          <svg style="width: 28px; height: 28px; fill: #0f172a; margin-left: 4px;" viewBox="0 0 24 24">
            <path d="M8 5v14l11-7z" />
          </svg>
        </div>
        <div style="position: absolute; bottom: 12px; left: 16px; color: white; z-index: 2; font-family: monospace; font-size: 0.9rem;">
          00:00 / 08:45
        </div>
      </div>

      <div class="card">
        <h2>Video-Details</h2>
        <div style="display: flex; flex-direction: column; gap: 8px; margin-top: 12px; color: var(--text-secondary); font-size: 0.95rem;">
          <div><strong>Veröffentlicht am:</strong> 1. Juni 2026</div>
          <div><strong>Aufrufe:</strong> 15.420 Views</div>
          <div><strong>Dauer:</strong> 8 Minuten, 45 Sekunden</div>
          <div><strong>Plattform:</strong> Interner Player & Schema.org-indexiert</div>
        </div>
      </div>
    </div>

    <div>
      <div class="schema-inspector">
        <h3>
          <svg style="width: 18px; height: 18px; fill: none; stroke: currentColor; stroke-width: 2;" viewBox="0 0 24 24">
            <path d="M16 16v1a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h2m5.66 0H14a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H7.66a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2z" />
          </svg>
          Registrierte @graph-Elemente
        </h3>
        <p style="font-size: 0.8rem; color: var(--text-secondary); margin-bottom: 12px;">
          Das VideoSchema wird vollständig als JSON-LD @graph-Element registriert und ausgegeben:
        </p>
        <pre id="json-preview">Lade Schema...</pre>
      </div>
    </div>
  </div>

  <script is:inline>
    setTimeout(() => {
      const scripts = document.querySelectorAll('script[type="application/ld+json"]');
      let videoData = null;

      scripts.forEach(script => {
        try {
          const parsed = JSON.parse(script.innerHTML);
          const nodes = parsed['@graph'] || [parsed];
          nodes.forEach(node => {
            if (node['@type'] === 'VideoObject') videoData = node;
          });
        } catch(e) {}
      });

      const previewEl = document.getElementById('json-preview');
      if (previewEl) {
        previewEl.innerText = videoData 
          ? JSON.stringify(videoData, null, 2)
          : 'Kein Video Schema auf dieser Seite gefunden';
      }
    }, 100);
  </script>
</Layout>
