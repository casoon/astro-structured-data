{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declarationMap": true,
    "types": ["astro/client"]
  },
  "include": ["src/**/*"],
  "exclude": ["src/components/**/*"]
}
