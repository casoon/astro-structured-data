{
  "name": "@casoon/astro-structured-data",
  "version": "1.1.1",
  "description": "An Astro integration to automatically generate structured data (JSON-LD) for articles, FAQs, products, breadcrumbs, local businesses, and events.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components.d.ts",
      "import": "./dist/components.js",
      "default": "./dist/components.js"
    },
    "./zod": {
      "types": "./dist/zod.d.ts",
      "import": "./dist/zod.js"
    }
  },
  "files": [
    "dist/",
    "src/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node scripts/build-components.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "astro",
    "astro-integration",
    "structured-data",
    "json-ld",
    "seo",
    "schema",
    "schema-org"
  ],
  "author": {
    "name": "Jörn Seidel",
    "email": "info@casoon.de",
    "url": "https://www.casoon.de"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/casoon/astro-structured-data"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "astro": "^5.0.0 || ^6.0.0-beta.0 || ^6.0.0 || ^7.0.0-alpha.0"
  },
  "dependencies": {
    "schema-dts": "^1.1.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "astro": "^6.0.0"
  }
}
